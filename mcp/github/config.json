{
  "_template": "claude-kit/mcp/github",
  "_verified_with": "@modelcontextprotocol/server-github@2.x",
  "_install": "Merge the 'github' key into mcpServers in ~/.claude/settings.json. Set GITHUB_TOKEN env var.",
  "github": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-github"],
    "env": {
      "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
    }
  }
}
