{
  "permissions": {
    "allow": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/test-on-edit.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
