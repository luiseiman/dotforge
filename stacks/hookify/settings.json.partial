{
  "_comment": "Merge con template/settings.json.tmpl. Bootstrap copies hooks/ + core/ to .claude/hooks/hookify/",
  "permissions": {
    "allow": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "python3 .claude/hooks/hookify/hookify-pretooluse.py"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python3 .claude/hooks/hookify/hookify-stop.py"
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "python3 .claude/hooks/hookify/hookify-userpromptsubmit.py"
      }
    ]
  },
  "_bootstrap_note": "Copy $DOTFORGE_DIR/stacks/hookify/hooks/ and $DOTFORGE_DIR/stacks/hookify/core/ to .claude/hooks/hookify/"
}
